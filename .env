# Google AI Studio API Key (for Gemini support)
GOOGLE_API_KEY=AIz-your-key-here

# OpenRouter API Key (get from https://openrouter.ai/keys) - Also used for audio processing
OPENROUTER_API_KEY=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

# Grok API Key (get from https://console.x.ai/)
